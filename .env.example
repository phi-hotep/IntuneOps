# Purpose: template of environment variables for local dev. Copy to .env (git-ignored) and fill in. Never commit the real .env.

# Tenant and app registration (local app-only / device-code dev)
INTUNEOPS_TENANT_ID=00000000-0000-0000-0000-000000000000
INTUNEOPS_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Auth mode selector: Interactive | DeviceCode | AppCertificate | AppSecret | ManagedIdentity
INTUNEOPS_AUTH_MODE=DeviceCode

# Certificate thumbprint (only if AUTH_MODE=AppCertificate; cert stays in the local store)
INTUNEOPS_CERT_THUMBPRINT=

# Client secret is intentionally omitted as a default path. If you must use AppSecret for a
# throwaway dev app, set it here in the git-ignored .env only. Prefer certificate auth.
# INTUNEOPS_CLIENT_SECRET=

# Sender mailbox for Graph Mail notifications (Phase 3)
INTUNEOPS_MAIL_SENDER=compliance-bot@your-dev-tenant.onmicrosoft.com
